# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent git tracking.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, if you're building an library, you should ignore Pipfile.lock.
#  Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally committed, but can be ignored.
#  poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally committed, but can be ignored.
# .pdm-plugins/
# .pdm-db/

